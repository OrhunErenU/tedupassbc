{
  "name": "tedu-pass",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @tedu-pass/web dev",
    "build": "pnpm --filter @tedu-pass/web build",
    "start": "pnpm --filter @tedu-pass/web start",
    "lint": "pnpm --filter @tedu-pass/web lint",
    "db:generate": "pnpm --filter @tedu-pass/db prisma:generate",
    "db:migrate": "pnpm --filter @tedu-pass/db prisma:migrate",
    "db:push": "pnpm --filter @tedu-pass/db prisma:deploy",
    "db:seed": "pnpm --filter @tedu-pass/db prisma:seed",
    "db:studio": "pnpm --filter @tedu-pass/db prisma:studio"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "esbuild"]
  }
}
